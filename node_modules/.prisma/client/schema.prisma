generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ATHLETE
  AGENT
  CLUB
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum FootPreference {
  LEFT
  RIGHT
  BOTH
}

enum AthleteLevel {
  PROFESSIONAL
  AMATEUR
  YOUTH
}

enum AvailabilityStatus {
  FREE
  EMPLOYED
}

enum AgencyStatus {
  REPRESENTED
  UNREPRESENTED
}

enum ContractorType {
  AGENT
  CLUB
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  RESCHEDULED
}

// ─── Base user ────────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  role          UserRole
  status        AccountStatus @default(PENDING_VERIFICATION)
  emailVerified Boolean       @default(false)
  phoneVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  athlete        Athlete?
  contractor     Contractor?
  emailCodes     EmailVerificationCode[]
  passwordResets PasswordReset[]

  @@map("users")
}

// ─── Athlete ──────────────────────────────────────────────────────────────────

model Athlete {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Required (cadastro inicial)
  fullName     String
  cpf          String             @unique
  birthDate    DateTime
  naturalidade String
  phone        String
  position     String
  dominantFoot FootPreference
  height       Float
  weight       Float
  level        AthleteLevel
  availability AvailabilityStatus @default(FREE)
  agencyStatus AgencyStatus       @default(UNREPRESENTED)

  // Identidade visual / vitrine
  jerseyNumber Int?
  avatarUrl    String?

  // Pretensão salarial (visível só para clubes)
  expectedSalary Decimal? @db.Decimal(10, 2)

  // Localização (dados pessoais)
  city  String?
  state String?

  // Redes e informações adicionais
  socialMedia    String?
  additionalInfo String?

  // Campos desnormalizados — espelham o SeasonStats mais recente para listagem rápida
  lastClub        String?
  goals           Int?
  assists         Int?
  gamesThisSeason Int?
  minutesPlayed   Int?

  seasonStats       SeasonStats[]
  videos            AthleteVideo[]
  profileViews      ProfileView[]
  proposalsReceived Proposal[]     @relation("AthleteProposals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("athletes")
}

// ─── Season Stats (Atributos Técnicos por ano) ───────────────────────────────

model SeasonStats {
  id        String  @id @default(cuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  year          Int
  goals         Int            @default(0)
  assists       Int            @default(0)
  gamesPlayed   Int            @default(0)
  minutesPlayed Int            @default(0)
  position      String
  height        Float
  weight        Float
  dominantFoot  FootPreference
  lastClub      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([athleteId, year])
  @@map("season_stats")
}

// ─── Athlete Videos ───────────────────────────────────────────────────────────

model AthleteVideo {
  id        String  @id @default(cuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  url       String
  title     String?
  year      Int
  createdAt DateTime @default(now())

  @@map("athlete_videos")
}

// ─── Contractor (Agent or Club) ───────────────────────────────────────────────

model Contractor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        ContractorType
  name        String
  phone       String
  cpf         String?        @unique
  cnpj        String?        @unique
  companyName String?

  socialMedia    String?
  additionalInfo String?
  avatarUrl      String?

  profileViewsMade ProfileView[]
  proposalsSent    Proposal[]    @relation("ContractorProposals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contractors")
}

// ─── Profile Views ────────────────────────────────────────────────────────────

model ProfileView {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  viewedAt     DateTime   @default(now())

  @@index([athleteId, viewedAt])
  @@index([contractorId])
  @@map("profile_views")
}

// ─── Proposals (Convites) ─────────────────────────────────────────────────────

model Proposal {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      Athlete    @relation("AthleteProposals", fields: [athleteId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation("ContractorProposals", fields: [contractorId], references: [id], onDelete: Cascade)

  status      ProposalStatus @default(PENDING)
  message     String?
  scheduledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([athleteId, status])
  @@index([contractorId])
  @@map("proposals")
}

// ─── Email verification ───────────────────────────────────────────────────────

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("email_verification_codes")
}

// ─── Password reset ───────────────────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}
