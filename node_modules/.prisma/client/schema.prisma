generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ATHLETE
  AGENT
  CLUB
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum FootPreference {
  LEFT
  RIGHT
  BOTH
}

enum AthleteLevel {
  PROFESSIONAL
  AMATEUR
  YOUTH
}

enum AvailabilityStatus {
  FREE
  EMPLOYED
}

enum AgencyStatus {
  REPRESENTED
  UNREPRESENTED
}

enum ContractorType {
  AGENT
  CLUB
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  RESCHEDULED
}

enum MediaType {
  VIDEO
  PHOTO
  EXTERNAL_LINK
}

enum MessageType {
  TEXT
  AUDIO
  INVITE_CARD
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ─── Base user ────────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  role          UserRole
  status        AccountStatus @default(PENDING_VERIFICATION)
  emailVerified Boolean       @default(false)
  phoneVerified Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  athlete        Athlete?
  contractor     Contractor?
  emailCodes     EmailVerificationCode[]
  passwordResets PasswordReset[]

  @@map("users")
}

// ─── Athlete ──────────────────────────────────────────────────────────────────

model Athlete {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName     String
  cpf          String             @unique
  birthDate    DateTime
  naturalidade String
  phone        String
  position     String
  dominantFoot FootPreference
  height       Float
  weight       Float
  level        AthleteLevel
  availability AvailabilityStatus @default(FREE)
  agencyStatus AgencyStatus       @default(UNREPRESENTED)

  gender         Gender   @default(MALE)
  jerseyNumber   Int?
  avatarUrl      String?
  expectedSalary Decimal? @db.Decimal(10, 2)

  city  String?
  state String?

  socialMedia    String?
  additionalInfo String?

  // Denormalized from most recent SeasonStats
  lastClub        String?
  goals           Int?
  assists         Int?
  gamesThisSeason Int?
  minutesPlayed   Int?

  seasonStats       SeasonStats[]
  media             AthleteMedia[]
  profileViews      ProfileView[]
  proposalsReceived Proposal[]     @relation("AthleteProposals")
  conversations     Conversation[]
  favoritedBy       Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([availability, level, position])
  @@index([availability, agencyStatus])
  @@index([state, availability])
  @@index([gender, availability])
  @@index([height])
  @@index([birthDate])
  @@map("athletes")
}

// ─── Season Stats ─────────────────────────────────────────────────────────────

model SeasonStats {
  id        String  @id @default(cuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  year          Int
  goals         Int            @default(0)
  assists       Int            @default(0)
  gamesPlayed   Int            @default(0)
  minutesPlayed Int            @default(0)
  position      String
  height        Float
  weight        Float
  dominantFoot  FootPreference
  lastClub      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([athleteId, year])
  @@map("season_stats")
}

// ─── Athlete Media (videos, photos, links) ────────────────────────────────────

model AthleteMedia {
  id        String  @id @default(cuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  mediaType     MediaType
  url           String
  title         String
  year          Int
  category      String?
  subcategory   String?
  gameInfo      String? // "Vitória 2 × 1 ABC · 14/10/2024"
  isPublic      Boolean   @default(true)
  fileSizeBytes Int?

  createdAt DateTime @default(now())

  @@index([athleteId, mediaType])
  @@map("athlete_media")
}

// ─── Contractor ───────────────────────────────────────────────────────────────

model Contractor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           ContractorType
  name           String
  phone          String
  cpf            String?        @unique
  cnpj           String?        @unique
  companyName    String?
  socialMedia    String?
  additionalInfo String?
  avatarUrl      String?

  profileViewsMade ProfileView[]
  proposalsSent    Proposal[]     @relation("ContractorProposals")
  conversations    Conversation[]
  favorites        Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contractors")
}

// ─── Favorites ────────────────────────────────────────────────────────────────

model Favorite {
  id           String     @id @default(cuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  athleteId    String
  athlete      Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([contractorId, athleteId])
  @@index([contractorId])
  @@map("favorites")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  lastMessageAt         DateTime?
  lastMessagePreview    String?
  athleteUnreadCount    Int       @default(0)
  contractorUnreadCount Int       @default(0)

  messages Message[]

  createdAt DateTime @default(now())

  @@unique([athleteId, contractorId])
  @@index([athleteId, lastMessageAt])
  @@index([contractorId, lastMessageAt])
  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId String
  type         MessageType @default(TEXT)
  content      String?
  audioUrl     String?
  proposalId   String? // for INVITE_CARD type

  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Profile Views ────────────────────────────────────────────────────────────

model ProfileView {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      Athlete    @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  viewedAt     DateTime   @default(now())

  @@index([athleteId, viewedAt])
  @@index([contractorId])
  @@map("profile_views")
}

// ─── Proposals ────────────────────────────────────────────────────────────────

model Proposal {
  id           String     @id @default(cuid())
  athleteId    String
  athlete      Athlete    @relation("AthleteProposals", fields: [athleteId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   Contractor @relation("ContractorProposals", fields: [contractorId], references: [id], onDelete: Cascade)

  status      ProposalStatus @default(PENDING)
  message     String?
  scheduledAt DateTime?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([athleteId, status])
  @@index([contractorId])
  @@map("proposals")
}

// ─── Email verification ───────────────────────────────────────────────────────

model EmailVerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("email_verification_codes")
}

// ─── Password reset ───────────────────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_resets")
}
