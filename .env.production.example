# ─── Banco (usado pelo container postgres E montado na DATABASE_URL da api) ───
# NUNCA coloque a senha REAL aqui — este arquivo é versionado (vai pro GitHub).
# A senha real fica só no .env do servidor (que é privado / fora do Git).
POSTGRES_USER=empregol
POSTGRES_PASSWORD=troque_por_uma_senha_forte
POSTGRES_DB=empregol

# ─── JWT (gere segredos com: openssl rand -base64 48) ─────────────────────────
JWT_SECRET=cole_aqui_um_segredo_com_no_minimo_32_caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=cole_aqui_outro_segredo_com_no_minimo_32_caracteres
JWT_REFRESH_EXPIRES_IN=30d

# ─── E-mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_sua_api_key_aqui
EMAIL_FROM=noreply@empregolstartup.com.br

# ─── CORS: domínio do seu frontend (sem barra no final) ───────────────────────
# Ex: https://app.empregol.com.br   — use * só em teste
CORS_ORIGIN=*

# ─── Firebase Admin (login social Google/Apple) ──────────────────────────────
# Use UMA das opções. NUNCA versione o service account real.
#  • Inline (recomendado em secret/CI): o JSON inteiro numa linha
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"empregol-4c702",...}
#  • Por caminho de arquivo montado no servidor:
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json

# OBS: a DATABASE_URL da API é montada automaticamente no docker-compose.yml
# apontando para o serviço "db". Você NÃO precisa defini-la aqui.
